FMC_HOST=replace_with_fmc_hostname
FMC_PORT=443
FMC_USERNAME=replace_with_username
FMC_PASSWORD=replace_with_password
FMC_VERIFY_TLS=false
FMC_TIMEOUT=30

# Leave empty to use the DOMAIN_UUID returned during authentication.
FMC_DOMAIN_UUID=

# Required only when retrieving rules from one access control policy.
FMC_ACCESS_POLICY_ID=

LAB_OBJECT_NAME=LAB15-NETWORK
LAB_OBJECT_VALUE=198.18.15.0/24
ALLOW_FMC_CHANGES=false

