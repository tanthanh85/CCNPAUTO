{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ccnpauto.example/schemas/loopbacks.schema.json",
  "title": "Lab 2 managed loopback source of truth",
  "type": "object",
  "additionalProperties": false,
  "required": ["loopbacks"],
  "properties": {
    "loopbacks": {
      "type": "array",
      "description": "Zero or more loopback interfaces managed by this project.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "description",
          "ipv4",
          "prefix_length",
          "enabled"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "minimum": 0,
            "maximum": 2147483647
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120,
            "pattern": "^[^\\r\\n]+$"
          },
          "ipv4": {
            "type": "string",
            "format": "ipv4"
          },
          "prefix_length": {
            "type": "integer",
            "minimum": 0,
            "maximum": 32
          },
          "enabled": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
