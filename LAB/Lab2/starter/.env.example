# Copy to .env and use values shown in the active DevNet Sandbox reservation.
IOSXE_HOST=REPLACE_WITH_SANDBOX_HOST_OR_IP
IOSXE_SSH_PORT=22
IOSXE_HTTPS_PORT=443
IOSXE_USERNAME=REPLACE_WITH_USERNAME
IOSXE_PASSWORD=REPLACE_WITH_PASSWORD

# Use always-on for read-only work or reserved for the configuration task.
SANDBOX_MODE=always-on

# Keep false until the guide explicitly enables the reserved-sandbox change task.
ALLOW_CONFIG_CHANGES=false

# DevNet lab devices commonly use a certificate that is not trusted by the workstation.
# Keep false only for this controlled sandbox; production clients must validate TLS.
VERIFY_TLS=false
