# Enter the connection details for the active IOS XE reservable sandbox.
IOSXE_HOST=REPLACE_WITH_SANDBOX_HOST_OR_IP
IOSXE_HTTPS_PORT=443
IOSXE_USERNAME=REPLACE_WITH_USERNAME
IOSXE_PASSWORD=REPLACE_WITH_PASSWORD
VERIFY_TLS=false

# Conservative client behavior for a shared training platform.
REQUESTS_PER_SECOND=5
IOSXE_CONNECT_TIMEOUT=10
IOSXE_READ_TIMEOUT=45
IOSXE_MAX_RETRIES=3

# Hard safety limits for the bounded HTTP 429 experiment.
BURST_MAX_REQUESTS=200
BURST_MAX_SECONDS=30
BURST_MAX_BACKOFFS=3
