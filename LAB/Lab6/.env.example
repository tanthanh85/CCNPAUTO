IOSXE_HOST=REPLACE_WITH_RESERVED_SANDBOX_HOST
IOSXE_RESTCONF_PORT=443
IOSXE_USERNAME=REPLACE_WITH_USERNAME
IOSXE_PASSWORD=REPLACE_WITH_PASSWORD
VERIFY_TLS=false

# Use an Ubuntu VPN-interface address that IOS XE can route to.
TELEMETRY_RECEIVER_IP=REPLACE_WITH_REACHABLE_WORKSTATION_IP
TELEMETRY_RECEIVER_PORT=57000
TELEMETRY_PERIOD_CS=1000
ALLOW_CONFIG_CHANGES=false
